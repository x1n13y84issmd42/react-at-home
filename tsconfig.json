{
	"compilerOptions": {
		"module": "esnext",
		"target": "ESNext",
		"lib": [
			"DOM",
			"DOM.Iterable",
			"DOM.AsyncIterable",
			"ESNext",
		],

		"rootDir": ".",
		"outDir": "lib",

		"noImplicitAny": true,
		"strictBindCallApply": true,
		"strictFunctionTypes": false,
		"experimentalDecorators": true,
		"allowSyntheticDefaultImports": true,
		"forceConsistentCasingInFileNames": true,
		
		"removeComments": true,
		"emitDecoratorMetadata": true,
		"declaration": true,
		"sourceMap": false,

		"incremental": true,
		"skipLibCheck": true,
	}
}
